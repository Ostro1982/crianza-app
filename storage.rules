rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Solo miembros de esa familia (familyId del doc usuarios/{uid} en Firestore == familyId del path).
    match /familias/{familyId}/{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.familyId == familyId;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
