rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userFamilyId() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.familyId;
    }

    match /usuarios/{userId} {
      // Read: cualquier user logueado (necesario para buscar por email y vincular padres)
      allow read: if isSignedIn();

      // Create/update tu propio doc, o un padre_* ghost dentro de tu familia
      allow create, update: if isSignedIn() && (
        userId == request.auth.uid ||
        (userId.matches('padre_.*') && request.resource.data.familyId == userFamilyId())
      );

      // Delete solo tu propio doc
      allow delete: if isSignedIn() && userId == request.auth.uid;
    }

    match /familias/{familyId}/{document=**} {
      // Solo miembros de esa familia
      allow read, write: if isSignedIn() && userFamilyId() == familyId;
    }

    // Cualquier otro path bloqueado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
